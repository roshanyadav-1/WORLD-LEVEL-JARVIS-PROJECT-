<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_aris_login"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        tools:context=".SettingsActivity">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="32dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                app:tint="#FFFFFF" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btn_back"
                android:layout_marginStart="8dp"
                android:text="@string/settings"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/batteryOptimizationHelpButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="@string/aris_not_working"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice &amp; Speech"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="@string/select_default_tts_voice"
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="8dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:background="@drawable/selection_window_background" />

                <NumberPicker
                    android:id="@+id/ttsVoicePicker"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:theme="@style/AppTheme.NumberPicker" />

            </FrameLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchShowThoughts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Show Agent Thoughts"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:thumbTint="#00E5FF"
                app:trackTint="#304060" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Display the agent's internal reasoning process on screen."
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/viewTaskLogsButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_aris_btn_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/view_task_logs"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/viewDiagnosticsButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_aris_input"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="System Diagnostics &amp; Health"
                android:textColor="#00E5FF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/viewHybridAutomationButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_aris_btn_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Hybrid Automation Engine"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/viewModelManagerButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_aris_input"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Offline LLM Model Manager"
                android:textColor="#00E5FF"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable 'Hey A.R.I.S!'"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/get_your_free_picovoice_api_key_you_can_paste_it_here"
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textGetPicovoiceKeyLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/get_your_free_accesskey_from_the_picovoice_console"
                android:textColor="#00E5FF"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/editWakeWordKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_aris_input"
                android:hint="Paste your key here"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#90A4AE"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textSensitivityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Sensitivity: 0.5"
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seekBarSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="10"
                android:progress="5" />

            <TextView
                android:id="@+id/wakeWordButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_aris_btn_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/enable_wake_word"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemini API Keys"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Enter your Gemini API keys (comma separated). These keys will be used in rotation to avoid limits."
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/editGeminiApiKeys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_aris_input"
                android:hint="key1,key2,key3..."
                android:inputType="textPassword"
                android:minLines="2"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#90A4AE"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/buttonSaveGeminiKeys"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_aris_input"
                android:text="Save API Keys"
                android:textColor="#00E5FF"
                android:textSize="14sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/textKeyHealthMonitorTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Key Health Monitor"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutKeyHealthMonitor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App Design Theme"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Choose your professional glowing aesthetic layout."
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_theme_default"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_aris_input"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Cyber Space"
                    android:textColor="#00E5FF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_theme_dark"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_aris_input"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Matrix Cyber"
                    android:textColor="#00E5FF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_theme_light"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_aris_input"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Cyberpunk"
                    android:textColor="#00E5FF"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:enabled="false"
                android:background="@drawable/bg_aris_input"
                android:hint="Your name"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#90A4AE"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/editUserEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_aris_input"
                android:hint="Your email"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:enabled="false"
                android:textColor="#FFFFFF"
                android:textColorHint="#90A4AE"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textProfileDisclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="This email will not be verified or stored by us. Please enter an accurate email so we don’t have to spend money to onboard you. We treat different emails as different users."
                android:textColor="#90A4AE"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/permissionsInfoButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="@string/why_permissions_needed"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/buttonSignOut"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_aris_input"
            android:gravity="center"
            android:text="@string/sign_out"
            android:textColor="#FF3D00"
            android:clickable="true"
            android:focusable="true" />
            
        <TextView
            android:id="@+id/appVersionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            android:textColor="#90A4AE"
            android:textSize="12sp"
            tools:text="Version 1.2.3" />

    </LinearLayout>

</ScrollView>
