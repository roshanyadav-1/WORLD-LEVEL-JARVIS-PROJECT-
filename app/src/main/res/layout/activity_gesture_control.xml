<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_aris_login"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Space HUD Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="56dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_gestures"
                app:tint="#00E5FF"
                android:background="@drawable/bg_circle_blue_transparent"
                android:padding="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A.R.I.S. Gesture HUD"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tony Stark-style handsfree air-controls"
                    android:textColor="#90A4AE"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Camera Permission / Preview Info Card -->
        <LinearLayout
            android:id="@+id/card_camera_opt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txt_camera_permission_title"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Front Camera Spatial Sensor"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_camera_status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISCONNECTED"
                    android:textColor="#FF3D00"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="#33FF3D00"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txt_camera_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Camera permission required to map fingers to floating screen space."
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/btn_setup_camera"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_aris_input"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">
                
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_camera_alt"
                    app:tint="#00E5FF" />
                    
                <TextView
                    android:id="@+id/btn_setup_camera_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Initialize Spatial Camera"
                    android:textColor="#00E5FF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- MediaPipe Hand Landmarker Neural Model Card -->
        <LinearLayout
            android:id="@+id/card_model_opt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Neural Hand Landmarker Model"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_model_status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOT INSTALLED"
                    android:textColor="#FF3D00"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="#33FF3D00"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txt_model_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Camera permission requires Google's official public 24 MB hand landmark file to map finger coordinates locally on device."
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <!-- Download Progress Indicator -->
            <LinearLayout
                android:id="@+id/layout_download_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/pb_download"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="#2979FF"
                    android:max="100"/>

                <TextView
                    android:id="@+id/txt_download_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Downloading: 0%"
                    android:textColor="#00E5FF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_download_model"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_aris_btn_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">
                
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_file_download"
                    app:tint="#FFFFFF" />
                    
                <TextView
                    android:id="@+id/btn_download_model_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Download Neural Model (24 MB)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Camera Preview Frame Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_camera_preview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#04060C"
            app:cardElevation="4dp"
            android:visibility="gone">

            <androidx.camera.view.PreviewView
                android:id="@+id/camera_preview_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:scaleType="fillCenter"/>

            <!-- Futuristic HUD corners -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FRONT SEN-FEED // REALTIME"
                    android:textColor="#00E5FF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:background="#A0000000"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true"/>

                <TextView
                    android:id="@+id/txt_preview_fps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60 FPS // LOCKED"
                    android:textColor="#00E5FF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:background="#A0000000"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Dynamic Hologram Projection Matrix View Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_aspect_ratio"
                    app:tint="#00E5FF"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Space Holo-Workspace (Live Simulator &amp; Tracker)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#304060"/>

            <!-- Our custom holographic workspace view -->
            <com.aris.voice.HoloWorkspaceView
                android:id="@+id/holo_workspace"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="#04060C"/>

            <!-- Telemetry HUD footer -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:padding="12dp"
                android:background="#04060C">

                <TextView
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:text="Hover Point: [X, Y]"
                    android:textColor="#90A4AE"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/txt_coordinate_telemetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tracking..."
                    android:textColor="#2979FF"
                    android:textSize="11sp"
                    android:gravity="end"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="wrap_content"
                    android:text="Spatial Action Status:"
                    android:textColor="#90A4AE"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/txt_gesture_action_telemetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="READY (Hover index finger tip)"
                    android:textColor="#00E5FF"
                    android:textSize="11sp"
                    android:gravity="end"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </GridLayout>

        </LinearLayout>

        <!-- Air Trigger Simulators Block (Allows seamless testing in preview/emulator) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Holo Air Command Board"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Simulate futuristic space actions using the controls below to verify dynamic hologram rotations, zoom ratios, and swipe feeds."
                android:textColor="#90A4AE"
                android:textSize="12sp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginTop="16dp"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <TextView
                    android:id="@+id/btn_sim_double_tap"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="40dp"
                    android:layout_margin="4dp"
                    android:text="Air Click"
                    android:textSize="12sp"
                    android:textColor="#00E5FF"
                    android:background="@drawable/bg_aris_input"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btn_sim_swipe"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="40dp"
                    android:layout_margin="4dp"
                    android:text="Swipe Feed"
                    android:textSize="12sp"
                    android:textColor="#00E5FF"
                    android:background="@drawable/bg_aris_input"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btn_sim_two_hand_zoom"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="40dp"
                    android:layout_margin="4dp"
                    android:text="Two-Hand Zoom"
                    android:textSize="12sp"
                    android:textColor="#00E5FF"
                    android:background="@drawable/bg_aris_input"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btn_sim_rotate"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_height="40dp"
                    android:layout_margin="4dp"
                    android:text="Matrix Rotate"
                    android:textSize="12sp"
                    android:textColor="#00E5FF"
                    android:background="@drawable/bg_aris_input"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>
            </GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#304060"
                android:layout_marginVertical="16dp"/>

            <!-- Switch to Toggle System Overlay Mouse Cursor (Real Device control!) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Air Mouse Overlay Cursor"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spawns visible glowing mouse pointer over screen"
                        android:textColor="#90A4AE"
                        android:textSize="10sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_system_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/Theme.Aris" />
            </LinearLayout>

        </LinearLayout>

        <!-- Sensitivity & Hover Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_aris_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spatial Sensitivity Metrics"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Index Finger Tip Tracking Speed"
                android:textColor="#90A4AE"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <SeekBar
                    android:id="@+id/seekbar_sensitivity"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="75"/>

                <TextView
                    android:id="@+id/txt_sensitivity_val"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="75%"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:gravity="end"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Cursor Responsiveness (Smoothing Factor)"
                android:textColor="#90A4AE"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <SeekBar
                    android:id="@+id/seekbar_smoothing"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:max="95"
                    android:progress="60"/>

                <TextView
                    android:id="@+id/txt_smoothing_val"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="0.60"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:gravity="end"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="A.R.I.S Real-Click Tap Threshold (Dwell Time)"
                android:textColor="#90A4AE"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <SeekBar
                    android:id="@+id/seekbar_dwell_time"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:max="2000"
                    android:progress="400"/>

                <TextView
                    android:id="@+id/txt_dwell_time_val"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="400ms"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:gravity="end"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
