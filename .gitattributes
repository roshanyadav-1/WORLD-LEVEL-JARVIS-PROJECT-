# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files that should always use LF endings
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# Explicitly declare binary files that should never be converted/modified
*.jar binary
*.png binary
*.webp binary
*.keystore binary
